<Project>
  <PropertyGroup>
    <!-- Shared target framework monikers — reference these in .csproj files -->
    <LibTfms>net8.0;net9.0;net10.0</LibTfms>
    <AppTfms>net8.0;net9.0;net10.0</AppTfms>
  </PropertyGroup>

  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591;NU1903</NoWarn>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <PropertyGroup>
    <Version>0.1.0</Version>
    <Authors>HoangSnowy</Authors>
    <Company>Jaina</Company>
    <Product>Jaina Framework</Product>
    <Copyright>Copyright © HoangSnowy 2024-2026</Copyright>
    <PackageProjectUrl>https://github.com/HoangSnowy/jaina-dotnet</PackageProjectUrl>
    <RepositoryUrl>https://github.com/HoangSnowy/jaina-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageIcon>icon.png</PackageIcon>
  </PropertyGroup>
</Project>
