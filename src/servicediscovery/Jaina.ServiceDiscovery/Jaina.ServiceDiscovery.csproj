<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(LibTfms)</TargetFrameworks>
    <Description>Service discovery + integrated HttpClient for Jaina framework. AddJainaHttpClient&lt;T&gt; wires service discovery, resilience pipeline, tenant header propagation, and correlation id propagation in one call. Tenant-aware endpoint resolution: tries {service}.{tenant} first, falls back to {service}.</Description>
    <PackageId>Jaina.ServiceDiscovery</PackageId>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\multitenancy\Jaina.MultiTenancy\Jaina.MultiTenancy.csproj" />
    <ProjectReference Include="..\..\observability\Jaina.Observability\Jaina.Observability.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.ServiceDiscovery" />
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />
  </ItemGroup>
</Project>
