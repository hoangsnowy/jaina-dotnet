<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(LibTfms)</TargetFrameworks>
    <Description>Localization helpers for Jaina framework — tenant-aware IStringLocalizer that looks up "{tenant}/{key}" first and falls back to the shared resource, plus an OTEL span per lookup so missing translations show up in observability tooling</Description>
    <PackageId>Jaina.Localization</PackageId>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\multitenancy\Jaina.MultiTenancy\Jaina.MultiTenancy.csproj" />
    <ProjectReference Include="..\..\observability\Jaina.Observability\Jaina.Observability.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Localization" />
    <PackageReference Include="Microsoft.Extensions.Localization.Abstractions" />
  </ItemGroup>
</Project>
