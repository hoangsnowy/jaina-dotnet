<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Opinionated health-check wiring for Jaina framework — exposes /health/live (process up) and /health/ready (deps up) and registers per-provider checks (Redis, RabbitMQ, SqlServer, NpgSql, Outbox lag)</Description>
    <PackageId>Jaina.HealthChecks</PackageId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
</Project>
